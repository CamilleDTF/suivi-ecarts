// Schema for "Suivi des écarts" — reconstruit à partir de l'application Power Apps
// d'origine (Dossiers -> Écarts -> Fiches SSE -> Plan d'action).
//
// Différences volontaires par rapport aux tables Excel d'origine :
// - vrais types Date/Enum au lieu de tout stocker en texte (source du bug corrigé
//   précédemment sur le champ "Date" d'EcartAmiante_1) ;
// - référence humaine (ex. "EC-2026-0007") générée dans une transaction avec
//   verrou, pour éviter la collision d'ID possible dans le code Power Fx d'origine
//   (Max(...)+1 sans verrou).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  UTILISATEUR
}

enum Origine {
  REMONTEE_TERRAIN
  AUDIT_INTERNE
  AUDIT_EXTERNE
  VISITE_CHANTIER
  CONTROLE_TERRAIN
  RONDE_SECURITE
  INCIDENT_ACCIDENT
  AUTRE
}

enum StatutDossierEcart {
  A_QUALIFIER
  OUVERT
  EN_COURS
  CLOTURE
}

enum TypeActivite {
  SS3_RETRAIT_ENCAPSULAGE
  SS4_INTERVENTION
  PREPARATION_CHANTIER
  REPLI_RESTITUTION
  GESTION_DECHETS
  MATERIEL
  ACTIVITE_SUPPORT
  AUTRE
}

enum StatutFiche {
  BROUILLON
  EN_COURS
  FINALISEE
}

enum TypeAction {
  CURATIVE
  CORRECTIVE
  PREVENTIVE
}

enum StatutAction {
  A_FAIRE
  EN_COURS
  EN_RETARD
  REALISEE
  VERIFIEE_EFFICACE
  ANNULEE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(UTILISATEUR)
  createdAt    DateTime @default(now())
}

// Compteur de séquence par (type d'entité, année), utilisé pour générer les
// références humaines de façon atomique (SELECT ... FOR UPDATE).
model ReferenceCounter {
  entite String
  annee  Int
  valeur Int    @default(0)

  @@id([entite, annee])
}

model Dossier {
  id            String             @id @default(cuid())
  reference     String             @unique
  dateDetection DateTime
  origine       Origine
  statut        StatutDossierEcart @default(A_QUALIFIER)
  declarant     String
  chantier      String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  modifiePar    String?
  modifieLe     DateTime?
  ecarts        Ecart[]
}

model Ecart {
  id                 String             @id @default(cuid())
  reference          String             @unique
  dossier            Dossier            @relation(fields: [dossierId], references: [id])
  dossierId          String
  dateDetection      DateTime
  origine            Origine
  statut             StatutDossierEcart @default(A_QUALIFIER)
  declarant          String
  typeActivite       TypeActivite?
  natures            String[]
  domaines           String[]
  pointsSensibles    String?
  graviteReelle      String?
  gravitePotentielle String?
  frequence          String?
  criticite          String?
  theme              String[]           @default([])
  description        String?
  mesureImmediate    String?
  cause              String?
  critereEfficacite  String?
  ficheSSECreee      Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  modifiePar         String?
  modifieLe          DateTime?
  fichesSSE          FicheSSE[]
  actions            Action[]
}

model FicheSSE {
  id                           String        @id @default(cuid())
  reference                    String        @unique
  ecart                        Ecart?        @relation(fields: [ecartId], references: [id])
  ecartId                      String?
  ecartAmiante                 EcartAmiante? @relation(fields: [ecartAmianteId], references: [id])
  ecartAmianteId               String?
  typeEvenement                String?
  numeroInterne                String?
  statutFiche                  StatutFiche   @default(BROUILLON)
  emetteur                     String?
  nomChantier                  String?
  dateHeure                    DateTime?
  lieuZone                     String?
  personnesImpliquees          String?
  temoins                      String?
  declarationExterneNecessaire Boolean?
  declarationExterneA          String?
  descriptionFactuelle         String?
  gravite                      String?
  frequence                    String?
  criticite                    String?
  typeAnalyse                  String?
  toutesActionsCloturees       Boolean?
  miseAJourNecessaire          String[]      @default([])
  procedureLaquelle            String?
  referenceDUERP               String?
  nouveauRisqueNecessaire      Boolean?
  referenceNouveauRisque       String?
  communicationInterne         Boolean?
  typeCommunication            String?
  validationNom                String?
  validationFonction           String?
  validationDate               DateTime?
  mesuresImmediatesPrises      String?
  dateEnvoi                    DateTime?
  domaine                      String[]      @default([])
  theme                        String[]      @default([])
  referencePreuve              String?
  createdAt                    DateTime      @default(now())
  updatedAt                    DateTime      @updatedAt
  modifiePar                   String?
  modifieLe                    DateTime?
  causes                       CauseArbre[]
  actions                      Action[]
}

// Arbre des causes d'une fiche SSE : hiérarchie de causes (auto-référencée),
// avec un marqueur de cause racine.
model CauseArbre {
  id             String       @id @default(cuid())
  ficheSSE       FicheSSE     @relation(fields: [ficheSSEId], references: [id])
  ficheSSEId     String
  parent         CauseArbre?  @relation("CauseArbreParent", fields: [parentId], references: [id])
  parentId       String?
  enfants        CauseArbre[] @relation("CauseArbreParent")
  libelle        String
  estCauseRacine Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

// Suivi des écarts amiante — entité autonome, comme dans l'app d'origine
// (EcartAmiante_1 n'était pas rattachée à Dossier/Ecart, seulement, en option,
// à une Fiche SSE quand un événement SSE en découlait).
model EcartAmiante {
  id                             String     @id @default(cuid())
  reference                      String     @unique
  date                           DateTime
  nomChantier                    String
  numeroChantier                 String
  conducteur                     String
  chef                           String
  zone                           String?
  processus                      String?
  typeAnalyse                    String?
  referenceAnalyse               String?
  typeEcart                      String?
  resultatAttendu                String?
  resultatObtenu                 String?
  description                    String?
  expositionAccidentelle         Boolean?
  personneConcernee              String?
  fie                            Boolean?
  medecinTravail                 String?
  besoinNouvelleAnalyse          Boolean?
  pasNouvelleAnalyse             String?
  dateNouvelleAnalyse            DateTime?
  laboratoireNouvelleAnalyse     String?
  chantierNouvelleAnalyse        String?
  resultatAttenduNouvelleAnalyse String?
  resultatObtenuNouvelleAnalyse  String?
  actionCloture                  String?
  statut                         StatutDossierEcart @default(OUVERT)
  dateCloture                    DateTime?
  evenementSSE                   Boolean    @default(false)
  createdAt                      DateTime   @default(now())
  updatedAt                      DateTime   @updatedAt
  modifiePar                     String?
  modifieLe                      DateTime?
  fichesSSE                      FicheSSE[]
  actions                        Action[]
}

// Une action est le plus souvent rattachée à un Écart, mais l'app d'origine
// permettait aussi d'en créer directement depuis une Fiche SSE ou un Écart
// amiante sans Écart associé (cas fréquent en pratique) — d'où les trois
// rattachements optionnels plutôt qu'un seul ecartId obligatoire.
model Action {
  id              String        @id @default(cuid())
  reference       String        @unique
  ecart           Ecart?        @relation(fields: [ecartId], references: [id])
  ecartId         String?
  ficheSSE        FicheSSE?     @relation(fields: [ficheSSEId], references: [id])
  ficheSSEId      String?
  ecartAmiante    EcartAmiante? @relation(fields: [ecartAmianteId], references: [id])
  ecartAmianteId  String?
  type            TypeAction
  action          String
  responsable     String
  echeance        DateTime?
  statut          StatutAction  @default(A_FAIRE)
  obligatoire     Boolean       @default(false)
  preuve          String?
  verifEfficacite String?
  origine         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  modifiePar      String?
  modifieLe       DateTime?
}
